# ← من MongoDB Atlas (مجاني)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/music_bot

# ══ اختياري ══
MAX_QUEUE=50
DEFAULT_VOLUME=100
MAX_DURATION=3600
